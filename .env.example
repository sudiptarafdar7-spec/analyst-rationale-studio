# Copy to .env and fill in. NEVER commit the real .env.
# Only infrastructure secrets live here — provider API keys (OpenAI, Anthropic,
# Gemini, Deepgram, YouTube, Dhan) are managed in-app via the api_keys table.

# --- Database ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ars

# --- Auth / crypto ---
JWT_SECRET=replace-with-a-long-random-string
# Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=replace-with-a-fernet-key
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

# --- App wiring ---
FRONTEND_ORIGIN=http://localhost:5173
JOB_FILES_DIR=job_files

# --- Worker (optional; used when Celery is enabled) ---
REDIS_URL=redis://localhost:6379/0

# --- Seed admin (used by `make seed` / scripts/seed.py) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
